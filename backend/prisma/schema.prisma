generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  password      String
  name          String
  monthlyGoalKm Float      @default(80)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  favorites     Favorite[]
  ratings       Rating[]
  comments      Comment[]
  rides         Ride[]
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  routeId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, routeId])
}

model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  routeId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, routeId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int
  routeId   String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Route {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  description String
  difficulty  String
  distance    Float
  duration    Float
  elevation   Int
  coordinates String   @default("[]")
  gpxFile     String   @default("")
  imageUrl    String
  highlights  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ride {
  id              Int       @id @default(autoincrement())
  userId          Int
  routeSlug       String?
  routeTitle      String
  status          String    @default("active")
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  elapsedSec      Int       @default(0)
  movingSec       Int       @default(0)
  distanceKm      Float     @default(0)
  avgSpeedKmh     Float?
  maxSpeedKmh     Float?
  avgPaceMinPerKm Float?
  maxOffRouteKm   Float     @default(0)
  routeCompletion Float?
  trackPoints     String    @default("[]")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model EmailSubscriber {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  active     Boolean  @default(true)
  unsubToken String   @unique
  createdAt  DateTime @default(now())
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
