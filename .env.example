# Frontend (Next.js) — скопируйте в .env или задайте в Coolify
# NEXT_PUBLIC_* попадают в браузер и нужны на этапе build

# URL бэкенда (без /api в конце)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Coolify / production — замените на публичный URL бэкенда:
# NEXT_PUBLIC_API_URL=https://your-backend.example.com
