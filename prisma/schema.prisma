generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Пользователь велосипедист
model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name          String
  monthlyGoalKm Float      @default(80)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  favorites Favorite[]
  ratings   Rating[]
  comments  Comment[]
  rides     Ride[]
}

// Избранные маршруты
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  routeId   String   // slug маршрута (например, "august-canal")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, routeId])
}

// Рейтинги маршрутов
model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  routeId   String   // slug маршрута
  rating    Int      // 1-5 звезд
  comment   String?  // Опциональный комментарий
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, routeId])
}

// Комментарии к маршрутам
model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int
  routeId   String   // slug маршрута
  text      String   // Текст комментария
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Велосипедные маршруты
model Route {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // Уникальный идентификатор для URL
  title       String   // Название маршрута
  description String   // Описание маршрута
  difficulty  String   // easy, medium, hard
  distance    Float    // Дистанция в км
  duration    Float    // Длительность в часах
  elevation   Int      // Перепад высот в метрах
  gpxFile     String   // Путь к GPX файлу
  imageUrl    String   // URL изображения
  highlights  String   // JSON массив достопримечательностей
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Записанная поездка / тренировка с GPS
model Ride {
  id                Int       @id @default(autoincrement())
  userId            Int
  routeSlug         String?
  routeTitle        String
  status            String    @default("active") // active | completed | cancelled
  startedAt         DateTime  @default(now())
  endedAt           DateTime?
  elapsedSec        Int       @default(0)
  movingSec         Int       @default(0)
  distanceKm        Float     @default(0)
  avgSpeedKmh       Float?
  maxSpeedKmh       Float?
  avgPaceMinPerKm   Float?
  maxOffRouteKm     Float     @default(0)
  routeCompletion   Float?
  trackPoints       String    @default("[]")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}
